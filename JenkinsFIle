pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins-deploy
  containers:
  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command: ['/busybox/cat']
    tty: true
    volumeMounts:
    - name: harbor-credentials
      mountPath: /kaniko/.docker
  - name: kubectl
    image: alpine/k8s:1.29.2
    command: ['sleep']
    args: ['9999999']
  volumes:
  - name: harbor-credentials
    secret:
      secretName: harbor-credentials
      items:
      - key: .dockerconfigjson
        path: config.json
"""
        }
    }

    parameters {
        choice(
            name: 'ACTION',
            choices: ['build-only', 'build-and-deploy', 'deploy-only'],
            description: 'Action a effectuer'
        )
        string(
            name: 'IMAGE_TAG_DEPLOY',
            defaultValue: 'latest',
            description: 'Tag image a deployer (utilise uniquement pour deploy-only)'
        )
    }

    environment {
        REGISTRY = "178.170.116.15:32400"
        IMAGE_NAME = "isaac/isaac-fansite"
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {
        stage('Build & Push') {
            when {
                expression { params.ACTION in ['build-and-deploy', 'build-only'] }
            }
            steps {
                container('kaniko') {
                    sh """
                        /kaniko/executor \
                          --dockerfile=.deploy/Dockerfile \
                          --context=. \
                          --destination=${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} \
                          --destination=${REGISTRY}/${IMAGE_NAME}:latest \
                          --insecure \
                          --skip-tls-verify
                    """
                }
            }
        }

        stage('Deploy') {
            when {
                expression { params.ACTION in ['build-and-deploy', 'deploy-only'] }
            }
            steps {
                container('kubectl') {
                    script {
                        def tag = params.ACTION == 'deploy-only' ? params.IMAGE_TAG_DEPLOY : env.IMAGE_TAG
                        sh """
                            kubectl set image deployment/isaac-fansite \
                                isaac-fansite=${REGISTRY}/${IMAGE_NAME}:${tag} \
                                -n apps
                            kubectl rollout status deployment/isaac-fansite -n apps
                        """
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline termine avec succes - Action: ${params.ACTION}"
        }
        failure {
            echo "Pipeline en echec - Action: ${params.ACTION}"
        }
    }
}