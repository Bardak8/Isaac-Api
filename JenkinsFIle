pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins-deploy
  containers:
  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command: ['/busybox/cat']
    tty: true
    volumeMounts:
    - name: harbor-credentials
      mountPath: /kaniko/.docker
  - name: kubectl
    image: bitnami/kubectl:latest
    command: ['sleep']
    args: ['9999999']
  volumes:
  - name: harbor-credentials
    secret:
      secretName: harbor-credentials
      items:
      - key: .dockerconfigjson
        path: config.json
"""
        }
    }

    environment {
        REGISTRY = "178.170.116.15:32400"
        IMAGE_NAME = "isaac/isaac-fansite"
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {
        stage('Build & Push') {
            steps {
                container('kaniko') {
                    sh """
                        /kaniko/executor \
                          --dockerfile=.deploy/Dockerfile \
                          --context=. \
                          --destination=${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} \
                          --destination=${REGISTRY}/${IMAGE_NAME}:latest \
                          --insecure \
                          --skip-tls-verify
                    """
                }
            }
        }

        stage('Deploy') {
            steps {
                container('kubectl') {
                    sh """
                        kubectl set image deployment/isaac-fansite \
                            isaac-fansite=${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} \
                            -n apps
                        kubectl rollout status deployment/isaac-fansite -n apps
                    """
                }
            }
        }
    }
}